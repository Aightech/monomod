# ESP-IDF firmware (covers all nested projects: main, lis3dh_node, bringup/*)
firmware/**/build/
firmware/build/
firmware/**/managed_components/
firmware/**/sdkconfig.old
firmware/**/dependencies.lock
# generated per-project config (regenerated from sdkconfig.defaults); main's
